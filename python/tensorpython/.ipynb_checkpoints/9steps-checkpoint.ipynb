   "source": [
    "# 求二次函数的最小值\n",
    "\n",
    "import tensorflow as tf\n",
    "sess = Session()\n",
    "x = Variable(tf.zeros([1]))\n",
    "\n",
    "y = 2*x*x+x+1\n",
    "train = tf.GrandientDescentOptimizer(0.01).minimize(y)\n",
    "\n",
    "tf.global_variable_initializer().run()\n",
    "\n",
    "for i in range(1000):\n",
    "    train.run()\n",
    "    \n",
    "print(x.eval())"
   ]
